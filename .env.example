# ============================================================
#  TGiCCC Backend — Environment Variables
#  Copy this file to .env and fill in your real values
# ============================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB Atlas ---
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/tgiccc?retryWrites=true&w=majority

# --- JWT Secret (use a long random string — never share this) ---
JWT_SECRET=replace_this_with_a_very_long_random_secret_key_min_32_chars
JWT_EXPIRES_IN=7d

# --- Email (Gmail SMTP) ---
# Enable "App Passwords" in your Google Account for this to work
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=TGiCCC Portal <your_gmail@gmail.com>

# --- Frontend URL (for CORS) ---
# Local development:  http://localhost:3000
# Production:         https://your-site.onrender.com
FRONTEND_URL=http://localhost:3000
